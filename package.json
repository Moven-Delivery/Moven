{
  "name": "moven",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "app",
    "landing"
  ],
  "scripts": {
    "dev:landing": "npm --workspace moven-landing run dev -- -p 3000",
    "dev:app": "npm --workspace moven-app run dev -- -p 3001",
    "build:landing": "npm --workspace moven-landing run build",
    "build:app": "npm --workspace moven-app run build",
    "start:landing": "npm --workspace moven-landing run start -- -p 3000",
    "start:app": "npm --workspace moven-app run start -- -p 3001",
    "lint:landing": "npm --workspace moven-landing run lint",
    "lint:app": "npm --workspace moven-app run lint"
  }
}
